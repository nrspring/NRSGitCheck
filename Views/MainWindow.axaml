<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NRSGitCheck.ViewModels"
        x:Class="NRSGitCheck.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        WindowState="Maximized">

  <DockPanel LastChildFill="True">

    <!-- Top bar: repo / target / view toggles get added here in later phases. -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Height="48">
      <TextBlock Text="{Binding Title}"
                 VerticalAlignment="Center"
                 Margin="16,0"
                 FontSize="15"
                 FontWeight="SemiBold" />
    </Border>

    <!-- Status bar: comparison summary / shortcut hints get added in later phases. -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Height="26">
      <TextBlock Text="{Binding Status}"
                 VerticalAlignment="Center"
                 Margin="12,0"
                 FontSize="12"
                 Opacity="0.8" />
    </Border>

    <!-- Content area: empty-state panel / file list + diff pane fill this region. -->
    <Panel Name="ContentRoot" />

  </DockPanel>

</Window>
