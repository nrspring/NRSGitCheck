<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NRSGitCheck.ViewModels"
        xmlns:views="using:NRSGitCheck.Views"
        xmlns:conv="using:NRSGitCheck.Converters"
        x:Class="NRSGitCheck.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        WindowState="Maximized">

  <DockPanel LastChildFill="True">

    <!-- Top bar -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            MinHeight="48">

      <Grid Margin="16,8" ColumnDefinitions="*,Auto">

       <Panel Grid.Column="0">

        <!-- No repo: just branding -->
        <TextBlock Text="{Binding Title}"
                   VerticalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   IsVisible="{Binding !HasRepo}" />

        <!-- Repo open: repo / branch / comparison target controls -->
        <WrapPanel Orientation="Horizontal"
                   VerticalAlignment="Center"
                   IsVisible="{Binding HasRepo}">

          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,16,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding RepositoryName}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="on" Opacity="0.6" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentBranch}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding HeadShortSha}" Opacity="0.6" FontFamily="Cascadia Code,Consolas,monospace" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,12,0" VerticalAlignment="Center">
            <TextBlock Text="Compare against" Opacity="0.6" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ComparisonModes}"
                      SelectedItem="{Binding SelectedMode}"
                      MinWidth="180"
                      VerticalAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ComparisonModeOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <AutoCompleteBox ItemsSource="{Binding LocalBranches}"
                             Text="{Binding SelectedBranch, Mode=TwoWay}"
                             PlaceholderText="branch…"
                             MinWidth="170"
                             FilterMode="ContainsOrdinal"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsOtherBranchMode}" />

            <AutoCompleteBox ItemsSource="{Binding LocalBranches}"
                             Text="{Binding ParentBranch, Mode=TwoWay}"
                             PlaceholderText="parent branch…"
                             MinWidth="170"
                             FilterMode="ContainsOrdinal"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsBranchBaseMode}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="→" Opacity="0.6" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ResolvedTargetLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>

          <Button Content="Refresh" Command="{Binding RefreshCommand}" Margin="0,0,6,0" VerticalAlignment="Center" />
          <Button Content="Open…" Command="{Binding OpenRepositoryCommand}" VerticalAlignment="Center" />
        </WrapPanel>
       </Panel>

       <!-- Theme selector: always available (FR-28) -->
       <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="12,0,0,0">
         <TextBlock Text="Theme" Opacity="0.6" VerticalAlignment="Center" />
         <ComboBox ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding SelectedTheme}" MinWidth="92" VerticalAlignment="Center">
           <ComboBox.ItemTemplate>
             <DataTemplate x:DataType="vm:ThemeOption">
               <TextBlock Text="{Binding Label}" />
             </DataTemplate>
           </ComboBox.ItemTemplate>
         </ComboBox>
       </StackPanel>
      </Grid>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Height="26">
      <TextBlock Text="{Binding Status}"
                 VerticalAlignment="Center"
                 Margin="12,0"
                 FontSize="12"
                 Opacity="0.8" />
    </Border>

    <!-- Content -->
    <Panel Name="ContentRoot">
      <views:EmptyStateView IsVisible="{Binding !HasRepo}" />

      <!-- Review layout: changed-files list (left) + detail/diff pane (right). -->
      <Grid IsVisible="{Binding HasRepo}" ColumnDefinitions="320,Auto,*">

        <!-- Left: changed-files list -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="8">
          <TextBox Grid.Row="0"
                   PlaceholderText="Filter files…"
                   Text="{Binding FileFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,6" />

          <TextBlock Grid.Row="1"
                     Text="{Binding ChangedFilesSummary}"
                     Opacity="0.7"
                     FontSize="12"
                     Margin="2,0,0,6" />

          <ListBox Grid.Row="2"
                   ItemsSource="{Binding Files}"
                   SelectedItem="{Binding SelectedFile}">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:FileChangeViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                  <Border Grid.Column="0"
                          Width="20" Height="20"
                          CornerRadius="3"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Background="{Binding Kind, Converter={x:Static conv:ChangeKindToBrushConverter.Instance}}">
                    <TextBlock Text="{Binding BadgeText}"
                               FontSize="11" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>

                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="binary" FontSize="10" Opacity="0.6" VerticalAlignment="Center"
                                 IsVisible="{Binding IsBinary}" />
                    </StackPanel>
                    <TextBlock Text="{Binding Directory}" FontSize="11" Opacity="0.55"
                               TextTrimming="CharacterEllipsis"
                               IsVisible="{Binding Directory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                  </StackPanel>

                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5"
                              VerticalAlignment="Center"
                              IsVisible="{Binding HasCounts}">
                    <TextBlock Text="{Binding AddedText}" Foreground="#4CAF50" FontSize="11" />
                    <TextBlock Text="{Binding DeletedText}" Foreground="#E05252" FontSize="11" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"
                      Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

        <!-- Right: the diff view for the selected file -->
        <views:DiffView Grid.Column="2" DataContext="{Binding Diff}" />
      </Grid>
    </Panel>

  </DockPanel>

</Window>
