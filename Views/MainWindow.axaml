<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NRSGitCheck.ViewModels"
        xmlns:views="using:NRSGitCheck.Views"
        xmlns:conv="using:NRSGitCheck.Converters"
        x:Class="NRSGitCheck.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="500"
        WindowState="Maximized">

 <Window.Styles>
   <!-- Rounded "pill" buttons used in the repo-picker ribbon. -->
   <Style Selector="Button.pill">
     <Setter Property="CornerRadius" Value="14" />
     <Setter Property="Padding" Value="12,5" />
   </Style>
 </Window.Styles>

 <Panel>
  <DockPanel LastChildFill="True">

    <!-- Top bar -->
    <Border DockPanel.Dock="Top"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            MinHeight="48">

      <Grid Margin="16,8" ColumnDefinitions="*,Auto">

       <DockPanel Grid.Column="0" LastChildFill="True">

        <!-- Repo picker toggle: reveals the recent-repos ribbon below the bar. -->
        <ToggleButton DockPanel.Dock="Left"
                      IsChecked="{Binding IsRepoRibbonVisible}"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"
                      Padding="12,5">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Repo" />
            <TextBlock Text="▾" FontSize="10" Opacity="0.7" VerticalAlignment="Center" />
          </StackPanel>
        </ToggleButton>

        <Panel>

        <!-- No repo: just branding -->
        <TextBlock Text="{Binding Title}"
                   VerticalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   IsVisible="{Binding !HasRepo}" />

        <!-- Repo open: repo / branch / comparison target controls -->
        <WrapPanel Orientation="Horizontal"
                   VerticalAlignment="Center"
                   IsVisible="{Binding HasRepo}">

          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,16,0" VerticalAlignment="Center">
            <TextBlock Text="{Binding RepositoryName}" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Text="on" Opacity="0.6" VerticalAlignment="Center" />
            <TextBlock Text="{Binding CurrentBranch}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding HeadShortSha}" Opacity="0.6" FontFamily="Cascadia Code,Consolas,monospace" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,12,0" VerticalAlignment="Center">
            <TextBlock Text="Compare against" Opacity="0.6" VerticalAlignment="Center" />
            <ComboBox ItemsSource="{Binding ComparisonModes}"
                      SelectedItem="{Binding SelectedMode}"
                      MinWidth="180"
                      VerticalAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ComparisonModeOption">
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <AutoCompleteBox ItemsSource="{Binding LocalBranches}"
                             Text="{Binding SelectedBranch, Mode=TwoWay}"
                             PlaceholderText="branch…"
                             MinWidth="170"
                             FilterMode="ContainsOrdinal"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsOtherBranchMode}" />

            <AutoCompleteBox ItemsSource="{Binding LocalBranches}"
                             Text="{Binding ParentBranch, Mode=TwoWay}"
                             PlaceholderText="parent branch…"
                             MinWidth="170"
                             FilterMode="ContainsOrdinal"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsBranchBaseMode}" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="→" Opacity="0.6" VerticalAlignment="Center" />
            <TextBlock Text="{Binding ResolvedTargetLabel}" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>

          <Button Content="Refresh" Command="{Binding RefreshCommand}" VerticalAlignment="Center" />
          <CheckBox Content="Auto" IsChecked="{Binding AutoRefreshEnabled}" VerticalAlignment="Center"
                    Margin="24,0,0,0"
                    ToolTip.Tip="Periodically check the repository for new changes" />
        </WrapPanel>
       </Panel>
       </DockPanel>

       <!-- Theme selector: always available (FR-28) -->
       <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="12,0,0,0">
         <TextBlock Text="Theme" Opacity="0.6" VerticalAlignment="Center" />
         <ComboBox ItemsSource="{Binding ThemeModes}" SelectedItem="{Binding SelectedTheme}" MinWidth="92" VerticalAlignment="Center">
           <ComboBox.ItemTemplate>
             <DataTemplate x:DataType="vm:ThemeOption">
               <TextBlock Text="{Binding Label}" />
             </DataTemplate>
           </ComboBox.ItemTemplate>
         </ComboBox>
       </StackPanel>
      </Grid>
    </Border>

    <!-- Repo-picker ribbon: open-folder action + recent-repo pills (FR-1, FR-3..4). -->
    <Border DockPanel.Dock="Top"
            IsVisible="{Binding IsRepoRibbonVisible}"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <StackPanel Spacing="10">

        <Button Command="{Binding OpenRepositoryCommand}"
                Classes="pill"
                FontWeight="SemiBold"
                HorizontalAlignment="Left">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="📂" />
            <TextBlock Text="Open folder…" />
          </StackPanel>
        </Button>

        <StackPanel Spacing="6" IsVisible="{Binding HasRecentRepositories}">
          <TextBlock Text="Recent" FontSize="11" Opacity="0.6" />
          <ItemsControl ItemsSource="{Binding RecentRepositories}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:RecentRepositoryViewModel">
                <Button Classes="pill"
                        Command="{Binding OpenCommand}"
                        Margin="0,0,8,8"
                        ToolTip.Tip="{Binding Path}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                    <TextBlock Text="missing" FontSize="10" Foreground="#FFE57373"
                               VerticalAlignment="Center"
                               IsVisible="{Binding !DirectoryExists}" />
                  </StackPanel>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="0,1,0,0"
            Height="26">
      <Grid ColumnDefinitions="*,Auto" Margin="12,0">
        <TextBlock Grid.Column="0" Text="{Binding Status}" VerticalAlignment="Center" FontSize="12" Opacity="0.8" />
        <TextBlock Grid.Column="1" Text="{Binding ShortcutHint}" VerticalAlignment="Center" FontSize="11" Opacity="0.55" Margin="12,0,0,0" />
      </Grid>
    </Border>

    <!-- Content -->
    <Panel Name="ContentRoot">
      <views:EmptyStateView IsVisible="{Binding !HasRepo}" />

      <!-- Review layout: changed-files list (left) + detail/diff pane (right). -->
      <Grid IsVisible="{Binding HasRepo}" ColumnDefinitions="320,Auto,*">

        <!-- Left: changed-files list -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="8">
          <TextBox Grid.Row="0"
                   Name="FilterBox"
                   PlaceholderText="Filter files…"
                   Text="{Binding FileFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   Margin="0,0,0,6" />

          <TextBlock Grid.Row="1"
                     Text="{Binding ChangedFilesSummary}"
                     Opacity="0.7"
                     FontSize="12"
                     Margin="2,0,0,6" />

          <TreeView Grid.Row="2"
                    ItemsSource="{Binding RootNodes}"
                    SelectedItem="{Binding SelectedNode, Mode=TwoWay}">
            <TreeView.Styles>
              <!-- Drive each folder's expand/collapse from its node, both ways. -->
              <Style Selector="TreeViewItem">
                <!-- ReflectionBinding: resolve IsExpanded against the runtime node,
                     not the window's compiled x:DataType. -->
                <Setter Property="IsExpanded" Value="{ReflectionBinding IsExpanded, Mode=TwoWay}" />
              </Style>
            </TreeView.Styles>
            <TreeView.DataTemplates>

              <!-- Folder: name + count of changed files beneath it. -->
              <TreeDataTemplate DataType="vm:FolderNode" ItemsSource="{Binding Children}">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,2">
                  <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                  <TextBlock Text="{Binding ChangedCountText}" Opacity="0.5" FontSize="11" VerticalAlignment="Center" />
                </StackPanel>
              </TreeDataTemplate>

              <!-- File: change badge + filename + line counts. -->
              <DataTemplate DataType="vm:FileNode">
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,2">
                  <Border Grid.Column="0"
                          Width="20" Height="20"
                          CornerRadius="3"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"
                          Background="{Binding File.Kind, Converter={x:Static conv:ChangeKindToBrushConverter.Instance}}">
                    <TextBlock Text="{Binding File.BadgeText}"
                               FontSize="11" FontWeight="Bold" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>

                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding File.FileName}" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding File.Path}" />
                    <TextBlock Text="binary" FontSize="10" Opacity="0.6" VerticalAlignment="Center"
                               IsVisible="{Binding File.IsBinary}" />
                  </StackPanel>

                  <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="5"
                              VerticalAlignment="Center"
                              IsVisible="{Binding File.HasCounts}">
                    <TextBlock Text="{Binding File.AddedText}" Foreground="#4CAF50" FontSize="11" />
                    <TextBlock Text="{Binding File.DeletedText}" Foreground="#E05252" FontSize="11" />
                  </StackPanel>
                </Grid>
              </DataTemplate>

            </TreeView.DataTemplates>
          </TreeView>
        </Grid>

        <GridSplitter Grid.Column="1" Width="4" ResizeDirection="Columns"
                      Background="{DynamicResource SystemControlForegroundBaseLowBrush}" />

        <!-- Right: the diff view for the selected file -->
        <views:DiffView Grid.Column="2" DataContext="{Binding Diff}" />
      </Grid>
    </Panel>

  </DockPanel>

  <!-- Busy overlay: shown while opening a repo or recomputing the diff (NFR-1). -->
  <Border IsVisible="{Binding IsBusy}" Background="#22000000">
    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24,18"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="12" MinWidth="180">
        <TextBlock Text="Working…" HorizontalAlignment="Center" Opacity="0.8" />
        <ProgressBar IsIndeterminate="True" Width="160" />
      </StackPanel>
    </Border>
  </Border>

  <!-- Keyboard shortcuts cheat-sheet overlay (FR-26) -->
  <Border IsVisible="{Binding IsHelpVisible}" Background="#99000000">
    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="24"
            MinWidth="420"
            HorizontalAlignment="Center" VerticalAlignment="Center">
      <StackPanel Spacing="12">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Grid.Column="0" Text="Keyboard shortcuts" FontSize="18" FontWeight="SemiBold" />
          <Button Grid.Column="1" Content="Close" Command="{Binding CloseHelpCommand}" Padding="10,3" />
        </Grid>
        <ItemsControl ItemsSource="{Binding Shortcuts}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ShortcutInfo">
              <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                <TextBlock Grid.Column="0" Text="{Binding Action}" />
                <TextBlock Grid.Column="1" Text="{Binding Keys}" FontFamily="Cascadia Code,Consolas,monospace"
                           Opacity="0.8" Margin="24,0,0,0" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
        <TextBlock Text="Press Esc to close" Opacity="0.5" FontSize="11" HorizontalAlignment="Center" />
      </StackPanel>
    </Border>
  </Border>

 </Panel>

</Window>
