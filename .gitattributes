## ----------------------
## Default behavior
## ----------------------
# Auto-detect text files and normalize line endings to LF in the repo.
* text=auto

## ----------------------
## Source / text files (force LF in repo)
## ----------------------
*.cs            text diff=csharp
*.csproj        text
*.sln           text eol=crlf
*.props         text
*.targets       text
*.config        text
*.json          text
*.xml           text
*.axaml         text
*.xaml          text
*.md            text
*.txt           text
*.yml           text
*.yaml          text
*.editorconfig  text
*.gitattributes text
*.gitignore     text

## ----------------------
## Windows-specific files (force CRLF)
## ----------------------
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf

## ----------------------
## Shell scripts (force LF)
## ----------------------
*.sh            text eol=lf

## ----------------------
## Binary files (never normalize/diff)
## ----------------------
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.bmp           binary
*.svg           text
*.ttf           binary
*.otf           binary
*.woff          binary
*.woff2         binary
*.eot           binary
*.dll           binary
*.exe           binary
*.pdb           binary
*.snk           binary
*.nupkg         binary
*.snupkg        binary
*.zip           binary
*.7z            binary
*.gz            binary
*.pdf           binary
